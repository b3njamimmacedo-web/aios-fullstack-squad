# ============================================================
# Meeting Intelligence - Variaveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# --- Chaves de API ---
OPENAI_API_KEY=sk-sua-chave-openai-aqui
ANTHROPIC_API_KEY=sk-ant-sua-chave-anthropic-aqui

# --- Configuracao de Audio ---
# Nome do dispositivo de audio virtual (ex: VB-Cable, CABLE Output)
# Use 'node src/cli.js devices' para listar dispositivos disponiveis
AUDIO_DEVICE=CABLE Output (VB-Audio Virtual Cable)
AUDIO_FORMAT=wav
AUDIO_SAMPLE_RATE=16000

# --- Caminhos ---
OBSIDIAN_VAULT_PATH=C:/Users/SeuUsuario/ObsidianVault
OUTPUT_DIR=./output
TEMP_DIR=./temp

# --- Dados da Empresa (para propostas geradas) ---
COMPANY_NAME=Sua Empresa Tech
COMPANY_LOGO_URL=https://suaempresa.com/logo.png
COMPANY_EMAIL=contato@suaempresa.com
COMPANY_PHONE=(11) 99999-9999
COMPANY_WEBSITE=https://suaempresa.com

# --- Precificacao ---
HOURLY_RATE=250
CURRENCY=BRL
DEFAULT_DISCOUNT=0

# --- Modelos de IA ---
CLAUDE_MODEL=claude-sonnet-4-20250514
WHISPER_MODEL=whisper-1
